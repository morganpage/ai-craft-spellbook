# =============================================================================
# AI Craft Spellbook - Arcane Keys Template
# =============================================================================
# Copy this file to .env and fill in your actual API keys and secrets
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# GOOGLE SERVICES (for Google Sheets/Slides integration)
# =============================================================================
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_PROJECT_ID=your_project_id
GOOGLE_REDIRECT_URI=http://localhost:8080

# =============================================================================
# OTHER MAGICAL SERVICES
# =============================================================================
# Add your API keys and secrets below as needed for your spells

# API_KEY_YOUR_SERVICE=your_api_key_here
# SECRET_YOUR_SERVICE=your_secret_here

# =============================================================================
# MAGICAL CONFIGURATION
# =============================================================================
# Spell-specific settings can go here

# Audio Cleanse Spell Defaults
# AUDIO_CLEANSE_DEFAULT_LOUDNESS=-14
# AUDIO_CLEANSE_DEFAULT_SILENCE_THRESHOLD=-40
# AUDIO_CLEANSE_DEFAULT_NOISE_STRENGTH=light

# Dispel Background Spell Defaults
# DISPEL_BACKGROUND_DEFAULT_MODEL=u2net
# DISPEL_BACKGROUND_MAX_FILE_SIZE=52428800

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Configure spell logging behavior

# LOG_LEVEL=INFO
# LOG_DIR=logs
# LOG_TO_CONSOLE=true
# LOG_TO_FILE=false

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Adjust resource usage and processing parameters

# Maximum file sizes (in bytes)
# MAX_AUDIO_SIZE=524288000
# MAX_IMAGE_SIZE=52428800
# MAX_VIDEO_SIZE=1073741824

# Batch processing settings
# BATCH_PARALLEL_WORKERS=4
# BATCH_PROGRESS_BAR=true

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Settings for development and testing

# DEBUG=false
# TEST_MODE=false
# KEEP_TEMP_FILES=false
# VERBOSE_LOGGING=false
